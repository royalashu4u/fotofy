# ============================================================
# Environment Variables — Fotofy AI Telegram Bot
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- Telegram ---
BOT_TOKEN=your_telegram_bot_token_from_botfather

# --- Firebase ---
# Path to your Firebase service account JSON file (for local dev)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Firebase project ID  
FIREBASE_PROJECT_ID=fotofy-ai

# Firebase Storage bucket
FIREBASE_STORAGE_BUCKET=fotofy-ai.firebasestorage.app

# --- Firebase credentials as JSON string (for Vercel env vars) ---
# Paste the entire content of firebase-credentials.json as a single line JSON string
FIREBASE_CREDENTIALS_JSON=

# --- App ---
# Your Vercel deployment URL (without trailing slash)
WEBHOOK_URL=https://your-app.vercel.app

# Secret token to verify Telegram webhook requests
WEBHOOK_SECRET=your_random_secret_string_here

# --- Pollinations.ai ---
POLLINATIONS_API_KEY=your_pollinations_ai_api_key
POLLINATIONS_MODEL=flux
POLLINATIONS_WIDTH=1024
POLLINATIONS_HEIGHT=1024

# --- Credit System ---
FREE_CREDITS_ON_SIGNUP=20
REFILL_CREDITS=20
REFILL_DAYS=3
